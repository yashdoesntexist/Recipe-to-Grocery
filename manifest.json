{
  "manifest_version": 3,
  "name": "Recipe to Grocery",
  "description": "Save recipes and see required ingredients while shopping online.",
  "version": "0.1.0",

  "permissions": [
    "activeTab",
    "scripting"
  ],

  "host_permissions": [
    "*://*.allrecipes.com/*",
    "*://*.foodnetwork.com/*",
    "*://*.walmart.com/*",
    "*://*.amazon.com/*",
    "*://*.amazonfresh.com/*",
    "*://*.bbcgoodfood.com/*",
    "*://*.epicurious.com/*",
    "*://*.delish.com/*",
    "http://localhost:5000/*",
    "http://localhost:5131/*"
  ],

  "background": {
    "service_worker": "background.js"
  },

  "content_scripts": [
    {
      "matches": [
        "*://*.allrecipes.com/*",
        "*://*.foodnetwork.com/*",
        "*://*.bbcgoodfood.com/*",
        "*://*.epicurious.com/*",
        "*://*.delish.com/*"
      ],
      "js": ["recipe-parser.js"]
    },
    {
      "matches": [
        "*://*.walmart.com/*",
        "*://*.walmart.ca/*",
        "*://*.amazon.com/*",
        "*://*.amazonfresh.com/*"
      ],
      "js": ["grocery-checker.js"]
    }
  ],
  "action": {
    "default_title": "Recipe to Grocery",
    "default_popup": "popup.html"
  }
}